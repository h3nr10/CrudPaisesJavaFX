<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.template.MainController"
            prefWidth="1300"
            prefHeight="750"
            stylesheets="@style.css">

        <top>
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header-bar">
                        <padding>
                                <Insets top="15" right="25" bottom="15" left="25"/>
                        </padding>
                        <Label text="CRUD Países" styleClass="header-title"/>
                </HBox>
        </top>

        <center>
                <HBox spacing="25">
                        <padding>
                                <Insets top="25" right="25" bottom="25" left="25"/>
                        </padding>

                        <VBox spacing="20" prefWidth="380" styleClass="card">

                                <Label text="Detalhes do País" styleClass="titulo-card"/>

                                <GridPane hgap="15" vgap="15">
                                        <columnConstraints>
                                                <ColumnConstraints halignment="RIGHT" minWidth="90"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>

                                        <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                                        <TextField fx:id="txtNome" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="Ex: Brasil"/>

                                        <Label text="Sigla:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                                        <TextField fx:id="txtSigla" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Ex: BR"/>

                                        <Label text="Capital:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                                        <TextField fx:id="txtCapital" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Ex: Brasília"/>

                                        <Label text="Área (km²):" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                                        <TextField fx:id="txtArea" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="Ex: 8515767"/>

                                        <Label text="PIB (Bilhão):" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
                                        <TextField fx:id="txtPib" GridPane.rowIndex="4" GridPane.columnIndex="1" promptText="Ex: 3770.0"/>

                                        <Label text="População:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
                                        <TextField fx:id="txtPopulacao" GridPane.rowIndex="5" GridPane.columnIndex="1" promptText="Ex: 214000000"/>

                                        <Label text="Poder Militar:" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="form-label"/>
                                        <TextField fx:id="txtMilitar" GridPane.rowIndex="6" GridPane.columnIndex="1" promptText="Ex: 0.2151"/>
                                </GridPane>

                                <Region VBox.vgrow="ALWAYS"/> <VBox spacing="10">
                                <HBox spacing="10">
                                        <Button text="Salvar" onAction="#salvar" styleClass="btn, btn-salvar" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <Button text="Atualizar" onAction="#atualizar" styleClass="btn, btn-atualizar" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                </HBox>
                                <HBox spacing="10">
                                        <Button text="Excluir" onAction="#excluir" styleClass="btn, btn-excluir" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <Button text="Limpar" onAction="#limpar" styleClass="btn, btn-limpar" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                </HBox>
                        </VBox>
                        </VBox>

                        <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="card">
                                <Label text="Registos Existentes" styleClass="titulo-card"/>

                                <TableView fx:id="tablePaises" VBox.vgrow="ALWAYS" onMouseClicked="#selecionarPais">
                                        <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                        </columnResizePolicy>
                                        <columns>
                                                <TableColumn fx:id="colId" text="ID" maxWidth="40"/>
                                                <TableColumn fx:id="colNome" text="País" minWidth="120"/>
                                                <TableColumn fx:id="colSigla" text="Sigla" maxWidth="60"/>
                                                <TableColumn fx:id="colCapital" text="Capital" minWidth="120"/>
                                                <TableColumn fx:id="colArea" text="Área" minWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
                                                <TableColumn fx:id="colPib" text="PIB (PPC)" minWidth="130" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                                                <TableColumn fx:id="colPopulacao" text="População" minWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                                                <TableColumn fx:id="colMilitar" text="Índice Militar" minWidth="100" style="-fx-alignment: CENTER;"/>
                                        </columns>
                                </TableView>
                        </VBox>
                </HBox>
        </center>
</BorderPane>